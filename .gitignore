# Dependencies & build output
node_modules/
dist/

# Synced build artifacts - generated from ../data and ../assets by
# scripts/sync-data.mjs (runs via predev/prebuild). Never edit by hand.
web/public/data/
web/public/assets/

# Saved-page asset dumps (images/css/fonts) - bulky and redundant across
# pages; only the .htm files themselves are needed as parser source data.
old/**/*_files/

# Local/machine-specific tool config
.claude/settings.local.json

# OS cruft
.DS_Store
Thumbs.db

# Local notes
AUDIT.md
